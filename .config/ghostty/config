font-family = "IosevkaTerm Nerd Font"
theme = github-dark
cursor-style = bar

# Report as xterm-256color so tmux's mouse handling works (Ghostty's own
# xterm-ghostty terminfo uses kmous=\E[< which tmux doesn't wire up correctly)
term = xterm-256color

# Option+B/F for word movement
keybind = opt+b=text:\x1bb
keybind = opt+f=text:\x1bf

# Option+Shift for WORD movement (whitespace-delimited)
keybind = opt+shift+b=text:\x1bB
keybind = opt+shift+f=text:\x1bF
keybind = opt+shift+left=text:\x1bB
keybind = opt+shift+right=text:\x1bF

# Shift+Enter inserts a newline without submitting (for Claude Code, etc.)
keybind = shift+enter=text:\x1b\r
